# Backend
BACKEND_PORT=8000
DATABASE_URL=postgresql://user:password@localhost:5432/dpsp
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# RAG
RAG_EMBEDDING_PROVIDER=sentence-transformers  # options: sentence-transformers, openai, cohere
RAG_EMBEDDING_MODEL=all-MiniLM-L6-v2
RAG_VECTORDB_DIR=rag/vectordb
RAG_DOCS_DIR=rag/docs
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=50
RAG_RETRIEVAL_K=4
# Only required when RAG_EMBEDDING_PROVIDER=openai or cohere:
# OPENAI_API_KEY=your-key-here
# COHERE_API_KEY=your-key-here

# ML
MODEL_PATH=ml/models/
DEVICE=cpu
